# Patient-derived data and experiment artifacts: never commit or upload.
data/
outputs/
predictions/
checkpoints/
metrics/
runs/
artifacts/
models/
weights/
logs/
cache/

# Medical images and volumes.
*.dcm
*.dicom
*.nii
*.nii.gz
*.nrrd
*.mha
*.mhd

# Model weights and exported graphs.
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx

# Patient-derived tables and raster images.
*.csv
*.tsv
*.xls
*.xlsx
*.parquet
*.png
*.jpg
*.jpeg
*.bmp
*.tif
*.tiff

# Explicitly synthetic, non-patient examples are the only table exception.
!examples/
!examples/*.synthetic.csv

# Environment and build products.
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# Local tool configuration.
.claude/
.agents/

# Resolved local configurations may contain filesystem paths.
resolved_config_*.yaml
